{
  "permissions": {
    "allow": [
      "Bash(npx vite build)",
      "Bash(npm run build)",
      "Bash(curl -s -X POST http://localhost:5000/api/auth/signup -H \"Content-Type: application/json\" --data-raw \"{\"\"email\"\":\"\"misctest@test.com\"\",\"\"password\"\":\"\"Test1234!\"\",\"\"nickname\"\":\"\"기타테스트\"\"}\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/code-rules.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/sql-injection.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/code-rules.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/sql-injection.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/final-check.sh"
          }
        ]
      }
    ]
  }
}
